rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'voiceSignature', 'isVoiceEnrolled', 'createdAt'])
          && data.uid is string
          && data.email is string
          && data.voiceSignature is list
          && data.voiceSignature.size() > 0
          && data.isVoiceEnrolled is bool
          && data.createdAt is string;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['voiceSignature', 'isVoiceEnrolled', 'email']);
      allow delete: if isOwner(userId);
    }

    // 2. Messages Collection
    match /messages/{messageId} {
      function isValidMessage(data) {
        return data.keys().hasAll(['senderId', 'senderName', 'encryptedText', 'timestamp'])
          && data.senderId is string
          && data.senderName is string
          && data.encryptedText is string
          && data.encryptedText.size() <= 5000
          && data.timestamp != null;
      }

      // Allow listing messages if signed in
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      // Strict write rules
      allow create: if isSignedIn() && isValidMessage(incoming()) 
        && incoming().senderId == request.auth.uid;
      
      // Allow deletion for purging purposes by any authenticated user in this private matrix
      allow update: if false;
      allow delete: if isSignedIn();
    }
  }
}
